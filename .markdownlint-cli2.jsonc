{
  "globs": [
    ".github/**/*.md",
    "AGENTS.md",
    "README.md",
    "docs/**/*.md",
    "tools/**/*.md",
    "!docs/AMPS_Server_Documentation*.md",
    "!tools/scraper/**/*.md",
    "!.opencode/**/*.md"
  ],
  "config": {
    "MD013": false,
    "MD014": false,
    "MD033": false,
    "MD036": false,
    "MD051": false,
    "MD060": {
      "style": "consistent"
    }
  }
}
